MAX_BOT_TOKEN=REPLACE_ME
MAX_WEBHOOK_SECRET=replace_me_please

# Публичный URL вашего webhook (для регистрации подписки в Max)
PUBLIC_BASE_URL=https://your-domain.example
WEBHOOK_PATH=/webhook/max

# База данных:
# - sqlite+aiosqlite:///./var/app.db  (по умолчанию)
# - postgresql+asyncpg://user:pass@host:5432/dbname
DATABASE_URL=sqlite+aiosqlite:///./var/app.db

# Админ‑ключ для внутреннего эндпоинта перезагрузки контента
ADMIN_API_KEY=replace_me_admin_key

# Лимиты/безопасность
RATE_LIMIT_PER_MINUTE=60
LOG_LEVEL=INFO
